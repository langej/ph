{
    "compilerOptions": {
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "bundler",
        "paths": {
            "@utils/*": ["./src/utils/*"],
            "@elements/*": ["./src/elements/*"],
            "@/*": ["./src/*"]
        },
        "esModuleInterop": true,
        "lib": ["DOM", "ES2020"],
        "strictPropertyInitialization": false,
        "noImplicitAny": false
    },
    "exclude": ["node_modules"]
}
